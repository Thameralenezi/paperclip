# syntax=docker/dockerfile:1.20
# Incremental patch: inject kimi adapter source + updated server dist.
# Uses tsx loader already in the production image — zero new npm deps.
FROM 606754308994.dkr.ecr.eu-north-1.amazonaws.com/cdk-hnb659fds-container-assets-606754308994-eu-north-1:paperclip-healthfix-1781011666

WORKDIR /app

# 1. Copy kimi-code package metadata + TypeScript source (no external deps)
COPY --chown=node:node packages/adapters/kimi-code/package.json packages/adapters/kimi-code/package.json
COPY --chown=node:node packages/adapters/kimi-code/tsconfig.json packages/adapters/kimi-code/tsconfig.json
COPY --chown=node:node packages/adapters/kimi-code/src packages/adapters/kimi-code/src

# 2. Create workspace symlink so Node resolves @paperclipai/adapter-kimi-code
RUN mkdir -p node_modules/@paperclipai && \
    ln -sfn /app/packages/adapters/kimi-code node_modules/@paperclipai/adapter-kimi-code

# 3. Replace server dist (includes kimi registry entries)
COPY --chown=node:node server/dist server/dist

# 4. Replace UI dist (includes kimi adapter display entry + config fields)
COPY --chown=node:node ui/dist ui/dist

# 5. Replace entrypoint so workspace bootstrap runs on every start
COPY --chown=root:root scripts/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh
