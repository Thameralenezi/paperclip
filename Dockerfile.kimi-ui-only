# syntax=docker/dockerfile:1.20
# Build just the UI with the kimi capabilities fix, extract ui/dist
FROM node:lts-trixie-slim AS build
ENV NODE_TLS_REJECT_UNAUTHORIZED=0
ENV npm_config_strict_ssl=false
WORKDIR /app

# Copy workspace config
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./

# Copy all package.json files for pnpm workspace install
COPY packages/adapter-utils/package.json packages/adapter-utils/
COPY packages/shared/package.json packages/shared/
COPY packages/adapters/kimi-code/package.json packages/adapters/kimi-code/
COPY packages/adapters/acpx-local/package.json packages/adapters/acpx-local/
COPY packages/adapters/claude-local/package.json packages/adapters/claude-local/
COPY packages/adapters/codex-local/package.json packages/adapters/codex-local/
COPY packages/adapters/cursor-cloud/package.json packages/adapters/cursor-cloud/
COPY packages/adapters/cursor-local/package.json packages/adapters/cursor-local/
COPY packages/adapters/gemini-local/package.json packages/adapters/gemini-local/
COPY packages/adapters/grok-local/package.json packages/adapters/grok-local/
COPY packages/adapters/openclaw-gateway/package.json packages/adapters/openclaw-gateway/
COPY packages/adapters/opencode-local/package.json packages/adapters/opencode-local/
COPY packages/adapters/pi-local/package.json packages/adapters/pi-local/
COPY packages/plugins/sdk/package.json packages/plugins/sdk/
COPY packages/skills-catalog/package.json packages/skills-catalog/
COPY packages/mcp-server/package.json packages/mcp-server/
COPY --parents packages/plugins/sandbox-providers/./*/package.json packages/plugins/sandbox-providers/
COPY packages/plugins/paperclip-plugin-fake-sandbox/package.json packages/plugins/paperclip-plugin-fake-sandbox/
COPY packages/plugins/plugin-llm-wiki/package.json packages/plugins/plugin-llm-wiki/
COPY packages/plugins/plugin-workspace-diff/package.json packages/plugins/plugin-workspace-diff/
COPY server/package.json server/
COPY ui/package.json ui/
COPY cli/package.json cli/
COPY patches/ patches/
COPY scripts/link-plugin-dev-sdk.mjs scripts/

RUN corepack enable && pnpm install --frozen-lockfile

# Copy full source
COPY . .

# Build UI
RUN pnpm --filter @paperclipai/ui build

FROM scratch
COPY --from=build /app/ui/dist /ui-dist
